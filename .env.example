# PostgreSQL de produccion. En Docker Desktop para Windows suele ser host.docker.internal.
PGHOST=host.docker.internal
PGPORT=5432
PGDATABASE=savh_erp
PGUSER=savh_user
PGPASSWORD=cambiar-por-password-real

# Debe coincidir con el major del servidor PostgreSQL para que pg_dump funcione.
PG_MAJOR=18

# Para usar la app localmente con Poetry, descomenta esta linea y copia
# config/config.local.example.toml a config/config.local.toml.
# SAVH_BACKUP_CONFIG=config/config.local.toml

# Sentry es opcional, pero recomendado en produccion.
SENTRY_DSN=

# Ruta al JSON del service account. Solo hace falta si usas provider=google_drive.
GOOGLE_APPLICATION_CREDENTIALS=/run/secrets/google-service-account.json

# Para Google Drive personal con provider=google_drive_oauth, usa por defecto:
# secrets/google-oauth-client.json para el client secret
# secrets/google-oauth-token.json para el token generado por google-drive-login

